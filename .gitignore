# Dependencies
node_modules/
.pnp
.pnp.js

# Testing
coverage/

# Next.js
.next/
out/
build/

# Production
*.tsbuildinfo
next-env.d.ts

# Environment — all .env files are gitignored, except the example.
# .env.example IS committed and is the only template file.
.env
.env.*
!.env.example

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Editor
.vscode/
.idea/
.DS_Store

# Prisma
prisma/migrations/dev.db*
# Prisma 7 generates the client into the project tree (no longer node_modules).
# It's build output — never commit.
prisma/generated/
prisma/seed.js

# Local backup target. Production sets BACKUP_HOST_DIR to /var/backups/...;
# local dev points it at ./backups so the workflow in .env.example
# (`mkdir -p backups`) doesn't dump real DB contents into git history.
backups/

# Serwist / PWA
public/sw.js
public/sw.js.map
public/swe-worker-*.js
public/workbox-*.js

# Playwright MCP persistent browser profile. Holds the auth.js session cookie
# after the one-time interactive login (see CLAUDE.md → "Verifying UI changes").
# Contains live credentials — never commit.
.playwright-profile/

# Playwright MCP scratch output (page snapshots, console logs, screenshots
# the MCP saves while Claude is verifying UI work).
.playwright-mcp/
