// Prisma schema — workout tracker
// Run `npx prisma migrate dev` after edits.

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
  // The connection URL lives in prisma.config.ts (Prisma 7 no longer accepts
  // it in the schema). At runtime, the Prisma client is constructed with a
  // PrismaPg driver adapter that reads DATABASE_URL directly — see lib/db.ts.
}

// ================================================================
// AUTH.JS TABLES (required by @auth/prisma-adapter)
// ================================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  accounts         Account[]
  sessions         AuthSession[]
  // App-side relations
  customExercises  Exercise[]             @relation("ExerciseOwner")
  workoutSessions  WorkoutSession[]
  volumeTargets    UserVolumeTarget[]
  preferences      UserPreferences?
  exerciseSettings ExerciseUserSettings[]
  templates        WorkoutTemplate[]
  hiddenTemplates  UserHiddenTemplate[]
  routine          Routine?
  notifications    Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model AuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ================================================================
// APP MODELS
// ================================================================

// Exercise represents both built-in (seeded) exercises and user-created custom ones.
// Built-in: ownerId is null, isCustom is false. Shared across all users.
// Custom:   ownerId is set, isCustom is true. Scoped to owner.
model Exercise {
  id           String  @id @default(cuid())
  name         String
  module       String // EXERCISE_MODULES values from lib/exercises-data.ts ('SMR Lower'…'Rev Up') or 'Custom' for user-created.
  prescription String? // Suggested set/rep scheme, e.g. "3×12, 5-sec hold"

  // 'reps' (default) or 'time'. Determines whether SetLog rows for this
  // exercise are measured in reps + weight, or in seconds. The set-row UI
  // renders a stopwatch + seconds input for 'time' exercises and the standard
  // reps/weight inputs otherwise. A handful of built-ins (planks, holds,
  // carries, wall sits) ship as 'time'; everything else stays 'reps'.
  metric String @default("reps")

  // Equipment tokens this exercise needs. Populated for built-ins; user-created
  // customs can leave it empty. Used by the starter-routine preset picker to
  // filter exercises by the user's available gear (full gym / home rack /
  // dumbbells / bands / bodyweight). 'mat' is informational rather than
  // gating — it surfaces in the preset preview as a small note.
  // Canonical tokens: 'barbell', 'rack', 'bench', 'dumbbells', 'cable',
  // 'machine', 'bands', 'pull-up bar', 'foam roller', 'lacrosse ball',
  // 'bodyweight', 'mat'. Empty array means "no equipment / always available."
  equipment String[] @default([])

  // Muscles trained, split by emphasis:
  //   primary   = the targets the lift was chosen for (full credit in volume)
  //   secondary = muscles meaningfully worked but not the focus (half credit)
  // Coverage (recency) treats both equally — being touched at all "freshens" a muscle.
  // Volume tracking weights them: each primary set counts 1.0; each secondary set counts 0.5.
  primaryMuscles   String[]
  secondaryMuscles String[] @default([])

  // Optional demonstration video. Manually added, no auto-fetching. UI surfaces
  // a small play icon when present.
  videoUrl String?

  isCustom Boolean @default(false)

  // Soft-delete: preserves historical SetLogs even after a user removes a custom from their list.
  deletedAt DateTime?

  ownerId String?
  owner   User?   @relation("ExerciseOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  setLogs SetLog[]

  // Per-user, per-exercise overrides (rest timer, etc.)
  userSettings ExerciseUserSettings[]

  // Templates this exercise appears in
  inTemplates TemplateExercise[]

  // Routine-day pending swaps that reference this exercise as outgoing or
  // incoming. Two named relations because both endpoints point at Exercise.
  pendingSwapsOut RoutineDayPendingSwap[] @relation("PendingSwapOut")
  pendingSwapsIn  RoutineDayPendingSwap[] @relation("PendingSwapIn")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ownerId, name])
  @@index([ownerId])
  @@index([module])
}

// Per-user override settings for an Exercise. One row per (user, exercise).
// Used so users can give built-in exercises their own rest-timer durations
// without needing to fork them. Custom exercises also use this table for
// consistency. Missing row = use UserPreferences defaults.
model ExerciseUserSettings {
  id         String @id @default(cuid())
  userId     String
  exerciseId String

  // Override the global default rest timer for just this exercise. Null means
  // "no override — use the global default."
  restTimerSeconds Int?

  // Override the global default weight-increment step for just this exercise.
  // Null = "use the global default." Useful for users who load DBs in 2.5lb
  // jumps but BBs in 5lb jumps, or for machines with stack-only increments.
  weightIncrement Float?

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, exerciseId])
  @@index([userId])
}

model WorkoutSession {
  id          String    @id @default(cuid())
  userId      String
  date        DateTime  @default(now())
  // Null while the workout is in progress; set when the user marks it complete.
  // At most one in-progress session per user is the convention (enforced by app, not DB).
  completedAt DateTime?

  // Set when this session was started from a RoutineDay (via the routine
  // timeline's "Start" affordance). Null for ad-hoc sessions and template-direct
  // starts. Sessions are durable records — if the routine day is later deleted,
  // we SetNull rather than cascade so history is preserved.
  startedFromRoutineDayId String?
  startedFromRoutineDay   RoutineDay? @relation(fields: [startedFromRoutineDayId], references: [id], onDelete: SetNull)

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  setLogs SetLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, date])
  @@index([userId, completedAt])
  @@index([startedFromRoutineDayId])
}

// Per-user override for weekly volume targets (sets/week for a muscle group).
// If no row exists for a (user, muscle), the app falls back to the default
// in lib/exercises-data.ts. Lets users tune targets to their own goals.
model UserVolumeTarget {
  id       String @id @default(cuid())
  userId   String
  muscleId String // Matches MuscleGroup.id, e.g. "glutes"
  target   Int // Sets per week

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, muscleId])
  @@index([userId])
}

// Per-user app preferences. One row per user, lazily created on first read.
// Fields default to sensible values, so a missing row = use all defaults.
model UserPreferences {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Rest timer settings
  restTimerEnabled Boolean @default(true)
  restTimerSeconds Int     @default(90) // Default rest period after each set
  restTimerSound   Boolean @default(true) // Play a chime when timer ends
  restTimerVibrate Boolean @default(true) // Vibrate when timer ends (mobile)

  // Set-seeding defaults. When an exercise is added to a session (picker or
  // template) and has no prior history to crib from, this many empty SetLogs
  // are pre-created. History wins when present; this is the fallback floor.
  defaultSetsPerExercise Int @default(3)

  // Weight stepper increment. The +/- buttons next to the weight input nudge
  // by this amount. Stored as Float so users on metric or with micro-plates
  // can use 1.25, 2.5, etc. Per-exercise overrides live on ExerciseUserSettings.
  defaultWeightIncrement Float @default(5)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// A named, reusable workout — a list of exercises in a chosen order. Loading a
// template into the active session creates an empty SetLog for each exercise
// so the user can start logging right away.
//
// Built-in: userId is null, isBuiltin is true. Shared across all users, seeded
//           from STARTER_TEMPLATES. A user can hide one (UserHiddenTemplate)
//           but can't delete it.
// User:     userId is set, isBuiltin is false. Owned by the user.
//
// Mirrors the Exercise built-in/custom split; a soft-delete column isn't
// needed because (a) users can't delete built-ins, and (b) deleting a user
// template doesn't need to preserve any history (no SetLog refers to a
// template, only to the exercises inside it).
model WorkoutTemplate {
  id          String  @id @default(cuid())
  userId      String?
  user        User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  isBuiltin   Boolean @default(false)
  name        String
  description String?

  exercises   TemplateExercise[]
  hiddenBy    UserHiddenTemplate[]
  // Routine days that reference this template. A user can't hard-delete a
  // template that's still in their routine — the action checks first and
  // returns a friendly error rather than relying on the FK to refuse.
  routineDays RoutineDay[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
  @@index([userId])
}

// Per-user hide marker for a built-in WorkoutTemplate. Built-ins are global,
// so there's no per-user delete; instead the user creates a hide row that
// excludes the template from their list. Removing the row unhides it.
// Only meaningful when the referenced template has isBuiltin=true; the app
// enforces that — there's no DB constraint.
model UserHiddenTemplate {
  id         String @id @default(cuid())
  userId     String
  templateId String

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  template WorkoutTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, templateId])
  @@index([userId])
}

// Junction row: an exercise inside a template, with its display position.
// On load, we copy these into SetLogs (one empty set per exercise) preserving
// the ordering. If the source exercise is later deleted, this row goes with it
// (Cascade) — the template degrades gracefully.
//
// plannedSets / plannedReps are the user's per-template planning numbers — how
// many sets and reps they intend to do for this exercise *in this template*.
// Both are nullable so existing rows and quick-pick flows can leave them
// blank. They feed buildSeededSetLogRows: when a session is started from a
// template (or a routine day), plannedSets becomes the seed set count when no
// history exists, and plannedReps fills in each seeded set's rep field. They
// are *plans*, not prescriptions: the user authored them; the app just
// represents them back.
model TemplateExercise {
  id         String          @id @default(cuid())
  templateId String
  template   WorkoutTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  exerciseId String
  exercise   Exercise        @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  position   Int

  plannedSets Int?
  // Used when the source Exercise.metric is 'reps'. Null = no plan.
  plannedReps Int?
  // Used when the source Exercise.metric is 'time'. Null = no plan. Only one of
  // plannedReps / plannedSeconds should be populated for a given row, dictated
  // by the exercise's metric; the actions enforce this rather than the schema.
  plannedSeconds Int?

  // Optional target weight (in user's stored unit) for metric='reps' exercises.
  // Null means "no plan — pick what feels right." Zero is allowed and means
  // bodyweight intentionally (so a reviewer's 'bodyweight' sticker resolves to
  // a concrete value). Like the other planned* fields, this is a hint surfaced
  // during the session — it is *not* a prescription the app polices.
  plannedWeight Float?

  // Free-text per-exercise note scoped to this routine day. The user types
  // tempo cues, breathing protocols, coach annotations — anything the
  // planned* numerics can't carry. Surfaced read-only in the active session
  // so the user sees it while lifting. Deliberately unstructured to keep
  // the app from re-prescribing what the user wrote.
  note String?

  createdAt DateTime @default(now())

  @@unique([templateId, exerciseId])
  @@index([templateId, position])
}

model SetLog {
  id         String  @id @default(cuid())
  sessionId  String
  exerciseId String
  setNumber  Int
  // Order of this exercise within the session. All sets of the same exercise
  // share the same position. Higher = later in the workout. Updated by the
  // reorderExercise action when the user moves an exercise up or down.
  position   Int     @default(0)
  // For exercises with metric='reps': how many reps were performed.
  reps       Int?
  // Stored as number; UI handles unit display. Only meaningful for metric='reps'.
  weight     Float?
  // For exercises with metric='time': how long the set was held, in seconds.
  // Mutually exclusive with reps in normal use; the writing actions populate
  // the right field based on the exercise's metric.
  seconds    Int?
  notes      String?

  session  WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exercise Exercise       @relation(fields: [exerciseId], references: [id], onDelete: Restrict)

  @@index([sessionId])
  @@index([sessionId, position])
  @@index([exerciseId])
}

// ================================================================
// ROUTINES
// ================================================================
//
// A Routine is the user's named cycle of templates. Templates are the plans
// for individual workouts; a routine is how those plans rotate. The app does
// not author or recommend routines — it represents the cycle the user
// declares ("last time I did A, this time B, then C, then loop"). Coverage
// remains the muscle-level signal; the routine is structure, not prescription.
//
// One routine per user (enforced by @unique on userId). Capped at 7 days.
// Two scheduling styles, picked when the routine is created:
//   - 'sequence': self-paced cycle. Cursor (lastCompletedPosition) advances
//     when a routine-started session is completed via completeActiveSession.
//   - 'weekday':  each day is pinned to a weekday (0=Sun..6=Sat). Calendar
//     drives "today's workout"; no cursor.

model Routine {
  id          String  @id @default(cuid())
  userId      String  @unique
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?

  // 'sequence' | 'weekday' — see comment above.
  scheduleStyle String @default("sequence")

  // Sequence mode only. The position of the most-recently-completed routine
  // session. Next-up = (lastCompletedPosition + 1) mod days.length. Null
  // until the user completes their first routine session.
  lastCompletedPosition Int?

  days   RoutineDay[]
  shares RoutineShare[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// One day within a Routine. Always has a position (display order, 0-indexed
// and contiguous). Has a weekday only in weekday mode. References an existing
// WorkoutTemplate — routines reuse the template concept rather than duplicate
// it, so editing a template propagates to every routine day that uses it.
model RoutineDay {
  id         String          @id @default(cuid())
  routineId  String
  routine    Routine         @relation(fields: [routineId], references: [id], onDelete: Cascade)
  templateId String
  template   WorkoutTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  position Int
  // Sequence mode: null. Weekday mode: 0-6, unique within a routine so a
  // weekday can't be double-booked. The unique constraint relies on Postgres
  // NULL semantics — multiple sequence-mode rows with weekday=null don't
  // collide.
  weekday  Int?
  // Optional user-defined label (e.g. "Heavy day"). The template name is
  // primary; this is auxiliary display text.
  label    String?
  // Longer free-text framing for the whole day (e.g. "Lower emphasis (glute
  // drive). Stack ~60 min: SMR → Mobility → Activation → Strength → Rev Up.").
  // Sibling to `label`: label is a short tag, description is a paragraph.
  // Routine.description covers the whole routine; this is per-day.
  description String?

  pendingSwaps RoutineDayPendingSwap[]
  // Sessions started from this day. SetNull on session.startedFromRoutineDayId
  // when this day is deleted, so completed sessions remain in history.
  sessions     WorkoutSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([routineId, position])
  @@unique([routineId, weekday])
  @@index([routineId])
}

// A one-time exercise substitution staged on a RoutineDay. Applied (and then
// cleared) when the day's session is started. Persists across calendar days —
// the user can stage a swap days in advance.
//
// Exercise relations are Cascade. For built-ins (no UI delete) this never
// fires. For user customs that hard-delete (rare; the UI soft-deletes), the
// pending swap goes away with the exercise. Soft-deleted exercises in a swap
// row are filtered out at apply time, since the swap action validates the
// incoming exercise is still available.
model RoutineDayPendingSwap {
  id           String     @id @default(cuid())
  routineDayId String
  routineDay   RoutineDay @relation(fields: [routineDayId], references: [id], onDelete: Cascade)

  outExerciseId String
  outExercise   Exercise @relation("PendingSwapOut", fields: [outExerciseId], references: [id], onDelete: Cascade)
  inExerciseId  String
  inExercise    Exercise @relation("PendingSwapIn", fields: [inExerciseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([routineDayId, outExerciseId])
  @@index([routineDayId])
}

// ================================================================
// ROUTINE SHARING
// ================================================================
//
// The owner mints an unguessable-token URL that gives a reviewer read access to
// their routine and lets the reviewer comment, react ("good"), and propose
// suggestions (structured: swap / reorder / insert / remove; advisory: sticker
// chips for more/less sets-reps-weight and free-text notes). The owner reviews
// the activity in an in-app inbox and one-click-applies structured suggestions
// the reviewer made.
//
// Reviewers are anonymous: a per-share `reviewerKey` cookie + display name
// they enter on first visit. Clearing cookies = new identity. This is a
// friend-review tool, not a multi-user system; the share link is the only
// access control. Owner can revoke the link to cut access.

model RoutineShare {
  id        String    @id @default(cuid())
  routineId String
  routine   Routine   @relation(fields: [routineId], references: [id], onDelete: Cascade)
  // Unguessable URL slug. Generated server-side via a 128-bit-ish random token.
  // The id is internal; this is what shows up in URLs.
  token     String    @unique
  // Optional human label so the owner can keep multiple links straight
  // ("Alice's review", "Coach feedback").
  label     String?
  revokedAt DateTime?

  reviewers   ShareReviewer[]
  comments    ShareComment[]
  suggestions ShareSuggestion[]
  reactions   ShareReaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([routineId])
}

// One row per (share, anonymous reviewer). reviewerKey is a long random
// identifier minted server-side and set as an HttpOnly cookie scoped to the
// share path. Two reviewers on the same browser can't accidentally collide
// because the cookie is shareId-scoped.
model ShareReviewer {
  id          String  @id @default(cuid())
  shareId     String
  share       RoutineShare @relation(fields: [shareId], references: [id], onDelete: Cascade)
  reviewerKey String
  displayName String

  comments    ShareComment[]
  suggestions ShareSuggestion[]
  reactions   ShareReaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shareId, reviewerKey])
  @@index([shareId])
}

// Polymorphic comment. `targetType` + `targetId` point at the routine itself,
// a routine day, or a template-exercise row (per-exercise notes). We rely on
// the app layer to validate the (type, id) shape rather than a real FK because
// the target is genuinely polymorphic. The id is opaque to the schema.
model ShareComment {
  id         String @id @default(cuid())
  shareId    String
  share      RoutineShare @relation(fields: [shareId], references: [id], onDelete: Cascade)
  reviewerId String
  reviewer   ShareReviewer @relation(fields: [reviewerId], references: [id], onDelete: Cascade)

  // 'routine' | 'routine_day' | 'template_exercise' | 'suggestion'
  targetType String
  targetId   String

  body       String
  resolvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shareId, targetType, targetId])
}

// Polymorphic structured suggestion. `kind` discriminates the payload JSON:
//   - 'swap_specific'   payload: { outExerciseId, inExerciseId }
//   - 'swap_anyof'      payload: { outExerciseId, candidateIds: string[] }
//   - 'swap_category'   payload: { outExerciseId, primaryMuscle?: string, module?: string }
//   - 'reorder'         payload: { orderedTemplateExerciseIds: string[] } (day-scoped)
//   - 'insert'          payload: { atPosition: number, exerciseIds: string[] }
//   - 'remove'          payload: { templateExerciseId }
//   - 'sticker'         payload: { kind: 'more_sets'|'fewer_sets'|'more_reps'|'fewer_reps'|'more_weight'|'less_weight'|'bodyweight' }
//   - 'custom_exercise' payload: { name, primaryMuscles: string[], module: string, notes?: string }
//   - 'holistic_add'    payload: { exerciseIds?: string[], description?: string }
//   - 'holistic_remove' payload: { exerciseIds?: string[], description?: string }
//
// `targetType` + `targetId` mirror ShareComment. For holistic suggestions the
// target is the routine itself; for sticker/swap/insert/remove the target is
// the routine day or template-exercise row depending on what makes sense.
model ShareSuggestion {
  id         String @id @default(cuid())
  shareId    String
  share      RoutineShare @relation(fields: [shareId], references: [id], onDelete: Cascade)
  reviewerId String
  reviewer   ShareReviewer @relation(fields: [reviewerId], references: [id], onDelete: Cascade)

  kind       String
  targetType String?
  targetId   String?

  // JSON payload; shape depends on kind. Validated at action boundary.
  payload Json

  // 'open' | 'applied' | 'rejected' | 'resolved'
  // 'applied' = owner one-click-applied the structured edit
  // 'rejected' = owner dismissed
  // 'resolved' = advisory-style suggestion the owner acknowledged (sticker, holistic)
  state      String   @default("open")
  resolvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shareId, state])
  @@index([shareId, targetType, targetId])
}

// Lightweight thumbs-up-style reaction. Currently only `kind: 'good'` exists,
// the schema is permissive so we can extend later. Unique per
// (reviewer, target, kind) so a reviewer's "good" is a toggle, not a tally.
model ShareReaction {
  id         String @id @default(cuid())
  shareId    String
  share      RoutineShare @relation(fields: [shareId], references: [id], onDelete: Cascade)
  reviewerId String
  reviewer   ShareReviewer @relation(fields: [reviewerId], references: [id], onDelete: Cascade)

  targetType String // 'template_exercise' | 'routine_day' | 'routine'
  targetId   String
  kind       String // 'good'

  createdAt DateTime @default(now())

  @@unique([reviewerId, targetType, targetId, kind])
  @@index([shareId, targetType, targetId])
}

// In-app inbox for the routine owner. Generic enough to extend to other
// notification kinds later (we explicitly chose not to ship web push or
// email yet — bell icon + dropdown is the only sink).
model Notification {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 'share_comment' | 'share_suggestion' | 'share_reaction'
  kind  String
  title String
  body  String?
  // Where to navigate when clicked, relative URL.
  url   String

  // Loose reference to the source row. Not a real FK — the source might be
  // deleted (revoked share, removed comment) and the notification should
  // remain readable.
  sourceType String?
  sourceId   String?

  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}
