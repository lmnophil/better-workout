    "lucide-react": "^0.468.0",
    "next": "^15.1.0",
    "next-auth": "5.0.0-beta.25",
    "pino": "^9.5.0",
    "prisma": "^7.8.0",
    "prom-client": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "serwist": "^9.0.11",
    "zod": "^3.24.1"
