# ============================================================================
# Workout Tracker — environment variables
# ============================================================================
#
# Copy this file to `.env` and fill in the values. Both local dev and Docker
# Compose deployment read from `.env`.
#
# .env MUST live next to docker-compose.yml in the repo root.
# It is gitignored. Never commit it.
#
# Generate all the random secrets in one go:
#     ./scripts/generate-secrets.sh
#
# ============================================================================

# ----- Required everywhere ---------------------------------------------------

# Auth.js JWT signing key. 32 bytes of randomness, base64-encoded.
# Generate with: openssl rand -base64 32
# ROTATING THIS LOGS EVERYONE OUT (existing JWTs become invalid). That's the
# correct response if you ever suspect it's leaked.
AUTH_SECRET=

# Google OAuth credentials.
# Get from: https://console.cloud.google.com/apis/credentials
#   1. Create OAuth 2.0 Client (type: Web application)
#   2. Add authorized redirect URI: ${AUTH_URL}/api/auth/callback/google
#      (e.g. http://localhost:3000/api/auth/callback/google for dev,
#       https://workout.example.com/api/auth/callback/google for prod)
# AUTH_GOOGLE_SECRET is sensitive; AUTH_GOOGLE_ID is public-safe.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Resend (magic-link emails).
# Get an API key from: https://resend.com/api-keys
# Free tier: 3,000 emails/month, 100/day — plenty for this app.
AUTH_RESEND_KEY=

# Sender address for magic links. The Resend domain backing this address must
# be verified at https://resend.com/domains (or use Resend's test domain
# `onboarding@resend.dev`, which only delivers to the address you registered
# with Resend — fine for first-run validation, not for real use).
AUTH_EMAIL_FROM=noreply@workout.wizphil.com

# ----- Local development only -----------------------------------------------
# Used when running `npm run dev`. A SQLite file resolved relative to the repo
# root, so the dev database lands at prisma/dev.db. Compose sets its own
# DATABASE_URL (a file on the app-data volume), so this is dev-only.

DATABASE_URL="file:./prisma/dev.db"

# Where the app is served. Auth.js uses this to build OAuth callback URLs.
# Local dev / docker compose on your laptop:  http://localhost:3000
# Production behind your reverse proxy:       https://workout.example.com
AUTH_URL="http://localhost:3000"

# ----- Observability (optional) ---------------------------------------------

# Pino log level: trace | debug | info | warn | error | fatal
# Default: info in prod, debug in dev. Bump to debug when investigating issues.
LOG_LEVEL=info

# Bearer token for /api/metrics (Prometheus scrape endpoint).
# Generate with: openssl rand -hex 32
# If unset, /api/metrics returns 503 — set it before pointing a scraper here.
METRICS_TOKEN=

# ----- Database backups -----------------------------------------------------
# There is no backup service. The database is a single SQLite file on the
# app-data Docker volume. Back it up by copying that file safely — via the
# SQLite backup API or while the app is stopped, not a plain `cp` of a live WAL
# database. See DEPLOY.md → "Backups".
