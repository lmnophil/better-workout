# ============================================================================
# Workout Tracker — environment variables
# ============================================================================
#
# Copy this file to `.env` and fill in the values. Both local dev and Docker
# Compose deployment read from `.env`.
#
# .env MUST live next to docker-compose.yml in the repo root.
# It is gitignored. Never commit it.
#
# Generate all the random secrets in one go:
#     ./scripts/generate-secrets.sh
#
# ============================================================================

# ----- Required everywhere ---------------------------------------------------

# Auth.js JWT signing key. 32 bytes of randomness, base64-encoded.
# Generate with: openssl rand -base64 32
# ROTATING THIS LOGS EVERYONE OUT (existing JWTs become invalid). That's the
# correct response if you ever suspect it's leaked.
AUTH_SECRET=

# Google OAuth credentials.
# Get from: https://console.cloud.google.com/apis/credentials
#   1. Create OAuth 2.0 Client (type: Web application)
#   2. Add authorized redirect URI: ${AUTH_URL}/api/auth/callback/google
#      (e.g. http://localhost:3000/api/auth/callback/google for dev,
#       https://workout.example.com/api/auth/callback/google for prod)
# AUTH_GOOGLE_SECRET is sensitive; AUTH_GOOGLE_ID is public-safe.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Resend (magic-link emails).
# Get an API key from: https://resend.com/api-keys
# Free tier: 3,000 emails/month, 100/day — plenty for this app.
AUTH_RESEND_KEY=

# Sender address for magic links.
# For dev/testing: onboarding@resend.dev (Resend's test domain, no verification)
# For prod: an address on a domain you've verified at https://resend.com/domains
AUTH_EMAIL_FROM=onboarding@resend.dev

# ----- Local development only -----------------------------------------------
# These are used when running `npm run dev` against a Postgres on localhost.
# Compose sets DATABASE_URL itself from POSTGRES_* below; you can leave this
# blank if you only ever run via `docker compose up`.

DATABASE_URL="postgres://postgres:devpass@localhost:5432/workout"

# Where the app is served. Auth.js uses this to build OAuth callback URLs.
AUTH_URL="http://localhost:3000"

# ----- Docker Compose deployment only ---------------------------------------
# These are read by docker-compose.yml. Ignored by `npm run dev`.

# The domain Caddy serves and obtains a Let's Encrypt cert for.
# DNS A/AAAA records for this domain must point to this host before launch.
DOMAIN=workout.example.com

# Database credentials. Compose constructs DATABASE_URL from these.
# Generate password with: openssl rand -base64 24
POSTGRES_USER=workout
POSTGRES_DB=workout
POSTGRES_PASSWORD=

# ----- Observability (optional) ---------------------------------------------

# Pino log level: trace | debug | info | warn | error | fatal
# Default: info in prod, debug in dev. Bump to debug when investigating issues.
LOG_LEVEL=info

# Bearer token for /api/metrics (Prometheus scrape endpoint).
# Generate with: openssl rand -hex 32
# If unset, /api/metrics returns 503 — set it before pointing a scraper here.
METRICS_TOKEN=

# ----- Database backups (compose only) --------------------------------------
# A `backup` service runs in compose alongside the app. Once a day it runs
# pg_dump and writes a gzipped SQL file to BACKUP_HOST_DIR. Local copies are
# pruned to BACKUP_KEEP_LOCAL files; rely on your offsite pipeline (which you
# bring) for long-term retention and encryption. The local files are NOT
# encrypted at rest.

# Host path where backup files land. Must exist and be writable by Docker.
# Example values:
#   /var/backups/workout
#   /opt/workout/backups
#   /mnt/big-disk/postgres-backups/workout
# Required when running compose. No default — be explicit about where data goes.
BACKUP_HOST_DIR=

# UTC hour for the daily backup, 00–23. Default 03 (3 AM UTC).
# Pick something off-peak for your timezone but not so late it conflicts with
# whatever your offsite pipeline runs on its end.
BACKUP_SCHEDULE_HOUR=03

# How many local backup files to retain before pruning oldest. Your offsite
# pipeline keeps the long history; this is just a short buffer in case the
# offsite is briefly unavailable. Default 7.
BACKUP_KEEP_LOCAL=7
