# Reference Caddy config for putting an existing Caddy in front of the
# workout tracker. The app container publishes port 3000 on the host;
# Caddy proxies to it.
#
# This file is documentation, not loaded by anything. Copy what you need
# into your real Caddyfile, replace `workout.example.com` with your domain,
# and `localhost:3000` with whatever the host:port is from Caddy's vantage
# point (same host → localhost:3000; different host → that host's IP:3000).

workout.example.com {
    encode gzip zstd

    # Block direct internet access to the metrics endpoint. The scraper
    # (Prometheus, etc.) should reach the app on the Docker network at
    # app:3000/api/metrics from inside the compose project, not via Caddy.
    handle /api/metrics {
        respond "Not Found" 404
    }

    # Service worker needs the right MIME type and shouldn't be cached
    @sw path /sw.js
    header @sw {
        Cache-Control "no-cache"
        Service-Worker-Allowed "/"
    }

    # Long-lived cache for static assets (Next.js fingerprints them)
    @static path /_next/static/*
    header @static Cache-Control "public, max-age=31536000, immutable"

    header {
        # HSTS — force HTTPS for a year. Comment out the first time if you're
        # still testing on a subdomain you might want to revert.
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
        -Server
    }

    reverse_proxy localhost:3000 {
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
        # Server Actions (every mutation in the app) are CSRF-checked by comparing
        # the browser's Origin against this host. Caddy sets it automatically, but
        # it's pinned here so the dependency is visible if you port this block to
        # another proxy — on nginx it's `proxy_set_header X-Forwarded-Host $host`.
        # Without it, behind a Host-rewriting proxy, pages load but saves 403.
        header_up X-Forwarded-Host {host}
    }

    log {
        output stdout
        format json
        level INFO
    }

    # Skip access logs for static asset noise so real traffic isn't drowned
    # out. App-level logs (server actions, errors) come from the app
    # container, not Caddy.
    @noisy path /_next/static/* /icons/* /favicon.ico /sw.js /manifest.webmanifest /api/healthz
    log_skip @noisy
}
